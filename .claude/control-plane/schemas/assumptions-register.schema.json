{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/assumptions-register.schema.json",
  "title": "Idea-to-MVP Assumptions Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "assumptions",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assumption_id",
          "phase",
          "statement",
          "category",
          "status"
        ],
        "properties": {
          "assumption_id": {
            "type": "string",
            "pattern": "^ASM-[A-Z0-9-]{4,64}$"
          },
          "phase": {
            "enum": [
              "discover",
              "define",
              "design",
              "build",
              "test",
              "launch",
              "feedback"
            ]
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "enum": [
              "market",
              "product",
              "ux",
              "design",
              "technical",
              "delivery",
              "quality",
              "analytics",
              "operations"
            ]
          },
          "status": {
            "enum": [
              "open",
              "validated",
              "invalidated",
              "retired"
            ]
          },
          "owner": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
          },
          "falsifiers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "artifact_paths": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/portablePath"
            },
            "uniqueItems": true
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?)(?:/(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?))*$"
    }
  }
}
