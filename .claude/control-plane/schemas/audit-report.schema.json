{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/audit-report.schema.json",
  "title": "Idea-to-MVP Audit Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "state_dir",
    "mode",
    "current_phase",
    "eligible_nodes",
    "blocked",
    "missing_artifacts",
    "stale_artifacts",
    "contradictory_artifacts",
    "improperly_approved_artifacts",
    "unmanaged_artifacts",
    "valid",
    "errors"
  ],
  "properties": {
    "state_dir": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "audit",
        "re-entry"
      ]
    },
    "current_phase": {
      "enum": [
        "discover",
        "define",
        "design",
        "build",
        "test",
        "launch",
        "feedback"
      ]
    },
    "current_node": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 33
        },
        {
          "type": "null"
        }
      ]
    },
    "earliest_incomplete_node": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 33
        },
        {
          "type": "null"
        }
      ]
    },
    "eligible_nodes": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 33
      }
    },
    "blocked": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_human_decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_artifacts": {
      "$ref": "#/$defs/findingList"
    },
    "stale_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "status",
          "path"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "review_required",
              "partially_stale",
              "fully_stale"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "contradictory_artifacts": {
      "$ref": "#/$defs/findingList"
    },
    "improperly_approved_artifacts": {
      "$ref": "#/$defs/findingList"
    },
    "unmanaged_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "inferred_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "phase",
          "node",
          "owner",
          "contract",
          "status",
          "path"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "phase": {
            "type": "string",
            "minLength": 1
          },
          "node": {
            "type": "integer",
            "minimum": 1,
            "maximum": 33
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "contract": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "baseline_established": {
      "type": "boolean"
    },
    "valid": {
      "type": "boolean"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "findingList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "path",
          "reason"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
