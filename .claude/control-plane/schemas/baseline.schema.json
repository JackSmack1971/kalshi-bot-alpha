{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/baseline.schema.json",
  "title": "Claude Code Control-Plane Run Baseline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "repository_root",
    "manifest_hash",
    "captured_at",
    "git_identity",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string"
    },
    "repository_root": {
      "type": "string",
      "minLength": 1
    },
    "manifest_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "git_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit_sha",
        "branch",
        "dirty",
        "dirty_summary"
      ],
      "properties": {
        "commit_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "branch": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        },
        "dirty_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "changed_paths",
            "staged_count",
            "unstaged_count",
            "untracked_count",
            "diff_hash"
          ],
          "properties": {
            "changed_paths": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "staged_count": {
              "type": "integer",
              "minimum": 0
            },
            "unstaged_count": {
              "type": "integer",
              "minimum": 0
            },
            "untracked_count": {
              "type": "integer",
              "minimum": 0
            },
            "diff_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256",
          "size_bytes",
          "kind",
          "source",
          "reason_included"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "kind": {
            "enum": [
              "file",
              "directory",
              "symlink"
            ]
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "reason_included": {
            "type": "string",
            "minLength": 1
          },
          "resolved_within_repository": {
            "type": "boolean"
          },
          "snapshot_path": {
            "type": "string",
            "pattern": "^baseline-artifacts/[a-f0-9]{64}$"
          },
          "snapshot_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "link_target": {
            "type": "string"
          }
        },
        "dependentRequired": {
          "snapshot_path": [
            "snapshot_sha256"
          ],
          "snapshot_sha256": [
            "snapshot_path"
          ]
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "symlink"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "link_target"
              ]
            },
            "else": {
              "not": {
                "required": [
                  "link_target"
                ]
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "file"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "snapshot_path",
                "snapshot_sha256"
              ]
            }
          }
        ]
      }
    }
  }
}
