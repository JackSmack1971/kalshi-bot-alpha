{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/risk-register.schema.json",
  "title": "Idea-to-MVP Risk Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "risks",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "risk_id",
          "category",
          "description",
          "likelihood",
          "impact",
          "exposure",
          "status"
        ],
        "properties": {
          "risk_id": {
            "type": "string",
            "pattern": "^RISK-[A-Z0-9-]{4,64}$"
          },
          "category": {
            "enum": [
              "product",
              "market",
              "design",
              "technical",
              "delivery",
              "quality",
              "security",
              "release",
              "operations",
              "analytics"
            ]
          },
          "phase": {
            "enum": [
              "discover",
              "define",
              "design",
              "build",
              "test",
              "launch",
              "feedback"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "likelihood": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "impact": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "exposure": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "status": {
            "enum": [
              "open",
              "watching",
              "mitigated",
              "accepted",
              "closed"
            ]
          },
          "owner": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
          },
          "early_indicator": {
            "type": "string",
            "minLength": 1
          },
          "mitigation": {
            "type": "string",
            "minLength": 1
          },
          "contingency": {
            "type": "string",
            "minLength": 1
          },
          "artifact_paths": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/portablePath"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?)(?:/(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?))*$"
    }
  }
}
