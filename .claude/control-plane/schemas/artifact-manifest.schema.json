{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/artifact-manifest.schema.json",
  "title": "Idea-to-MVP Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "artifacts",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "artifacts": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "phase",
          "owner",
          "path",
          "status"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{2,63}$"
          },
          "artifact_type": {
            "type": "string",
            "minLength": 1
          },
          "phase": {
            "enum": [
              "discover",
              "define",
              "design",
              "build",
              "test",
              "launch",
              "feedback"
            ]
          },
          "node": {
            "type": "integer",
            "minimum": 1,
            "maximum": 33
          },
          "owner": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
          },
          "owners": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "reviewers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "path": {
            "$ref": "#/$defs/portablePath"
          },
          "status": {
            "enum": [
              "proposed",
              "draft",
              "reviewed",
              "approved",
              "conditionally_approved",
              "superseded",
              "rejected",
              "archived",
              "review_required",
              "partially_stale",
              "fully_stale",
              "still_valid"
            ]
          },
          "contract": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "source_artifacts": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/portablePath"
            },
            "uniqueItems": true
          },
          "supersedes": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/portablePath"
            },
            "uniqueItems": true
          },
          "downstream_consumers": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/portablePath"
            },
            "uniqueItems": true
          },
          "evidence_paths": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/portablePath"
            },
            "uniqueItems": true
          },
          "decision_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "requirement_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "signal_summary": {
            "type": "string",
            "minLength": 1
          },
          "hypothesis_assessment": {
            "type": "string",
            "minLength": 1
          },
          "data_quality_risks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "rollback_evidence": {
            "type": "string",
            "minLength": 1
          },
          "operational_owner": {
            "type": "string",
            "minLength": 1
          },
          "health_check_summary": {
            "type": "string",
            "minLength": 1
          },
          "deployment_recommendation": {
            "enum": [
              "ready",
              "conditional",
              "blocked"
            ]
          },
          "partial_deployment_safety": {
            "type": "string",
            "minLength": 1
          },
          "database_migration_strategy": {
            "type": "string",
            "minLength": 1
          },
          "release_candidate_ref": {
            "type": "string",
            "minLength": 1
          },
          "tested_candidate_ref": {
            "type": "string",
            "minLength": 1
          },
          "reproducibility_summary": {
            "type": "string",
            "minLength": 1
          },
          "security_disposition": {
            "enum": [
              "resolved",
              "mitigated",
              "accepted"
            ]
          },
          "security_accepting_human": {
            "type": "string",
            "minLength": 1
          },
          "security_review_condition": {
            "type": "string",
            "minLength": 1
          },
          "event_validation_report": {
            "type": "string",
            "minLength": 1
          },
          "hypothesis_evaluation": {
            "type": "string",
            "minLength": 1
          },
          "metrics_readiness": {
            "enum": [
              "ready",
              "conditional",
              "blocked"
            ]
          },
          "analytics_risks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "known_limitations": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "post_release_review": {
            "type": "string",
            "minLength": 1
          },
          "release_notes": {
            "type": "string",
            "minLength": 1
          },
          "release_recommendation": {
            "enum": [
              "ready",
              "conditional",
              "blocked"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?)(?:/(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?))*$"
    }
  }
}
