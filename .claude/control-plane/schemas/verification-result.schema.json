{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/verification-result.schema.json",
  "title": "Claude Code Control-Plane Verification Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "verdict",
    "verifier",
    "verified_at",
    "assertions",
    "evidence",
    "author_context_separate"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL",
        "INDETERMINATE"
      ]
    },
    "verifier": {
      "type": "string",
      "minLength": 1
    },
    "verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assertion_id",
          "result",
          "explanation",
          "evidence_locations"
        ],
        "properties": {
          "assertion_id": {
            "type": "string"
          },
          "result": {
            "enum": [
              "PASS",
              "FAIL",
              "INDETERMINATE",
              "NOT_APPLICABLE"
            ]
          },
          "explanation": {
            "type": "string",
            "minLength": 1
          },
          "evidence_locations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "remediation": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "verifier_identity"
      ],
      "properties": {
        "verifier_identity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": {
              "const": ".claude/agents/control-plane-verifier.md"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        }
      }
    },
    "author_context_separate": {
      "const": true
    }
  }
}
