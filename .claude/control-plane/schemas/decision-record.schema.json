{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/decision-record.schema.json",
  "title": "Idea-to-MVP Decision Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "category",
    "title",
    "status",
    "recorded_at",
    "authors",
    "context",
    "decision",
    "rationale"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "decision_id": {
      "type": "string",
      "pattern": "^DEC-[A-Z0-9-]{4,64}$"
    },
    "category": {
      "enum": [
        "product",
        "architecture",
        "scope",
        "risk",
        "release",
        "ux",
        "security",
        "process"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "proposed",
        "approved",
        "rejected",
        "superseded"
      ]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deciders": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "context": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "consequences": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "related_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/portablePath"
      },
      "uniqueItems": true
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^DEC-[A-Z0-9-]{4,64}$"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?)(?:/(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?))*$"
    }
  }
}
