{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/handoff.schema.json",
  "title": "Idea-to-MVP Handoff Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "handoff_id",
    "workflow_node",
    "objective",
    "assigned_agent",
    "authoritative_inputs",
    "allowed_paths",
    "tool_permissions",
    "required_output",
    "acceptance_checks",
    "forbidden_actions",
    "unresolved_questions",
    "execution_contract",
    "reviewer"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "handoff_id": {
      "type": "string",
      "pattern": "^HO-[A-Z0-9-]{4,64}$"
    },
    "workflow_node": {
      "type": "integer",
      "minimum": 1,
      "maximum": 33
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "assigned_agent": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "authoritative_inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/portablePath"
      },
      "uniqueItems": true
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owned_paths",
        "read_only_paths"
      ],
      "properties": {
        "owned_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/portablePath"
          },
          "uniqueItems": true
        },
        "read_only_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/portablePath"
          },
          "uniqueItems": true
        }
      }
    },
    "tool_permissions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "required_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "contract"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/portablePath"
        },
        "contract": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "acceptance_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "changed_paths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repoRelativePath"
      },
      "uniqueItems": true
    },
    "completion_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "artifacts_modified",
        "evidence_used",
        "validation_performed",
        "delegated_decisions",
        "escalations",
        "assumptions_introduced",
        "risks_discovered",
        "recommended_next_node",
        "status"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "artifacts_modified": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/portablePath"
          },
          "uniqueItems": true
        },
        "evidence_used": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/portablePath"
          },
          "uniqueItems": true
        },
        "validation_performed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "delegated_decisions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "escalations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "assumptions_introduced": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risks_discovered": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recommended_next_node": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 33
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "enum": [
            "complete",
            "conditional",
            "blocked",
            "failed"
          ]
        }
      }
    },
    "unresolved_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "execution_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shared_contracts",
        "expected_outputs",
        "validation_command",
        "completion_signal"
      ],
      "properties": {
        "shared_contracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "starting_commit": {
          "type": "string",
          "minLength": 1
        },
        "starting_branch": {
          "type": "string",
          "minLength": 1
        },
        "expected_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/portablePath"
          },
          "uniqueItems": true
        },
        "merge_order": {
          "type": "string",
          "minLength": 1
        },
        "conflict_owner": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
        },
        "validation_command": {
          "type": "string",
          "minLength": 1
        },
        "completion_signal": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reviewer": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    }
  },
  "$defs": {
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?)(?:/(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?))*$"
    },
    "repoRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.?[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?)(?:/(?:\\.?[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?))*$"
    }
  }
}
