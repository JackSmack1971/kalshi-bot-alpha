{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/replay-result.schema.json",
  "title": "Claude Code Control-Plane Historical Replay Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "replay_version",
    "harness_version",
    "replay_id",
    "candidate_id",
    "candidate_run_id",
    "hypothesis_id",
    "candidate_package_hash",
    "candidate_patch_hash",
    "hypothesis_policy_hash",
    "source_run_ids",
    "success_criterion",
    "evaluator",
    "minimum_effect",
    "minimum_evidence_count",
    "started_at",
    "finished_at",
    "results",
    "aggregate",
    "errors"
  ],
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "classification": {
      "enum": ["IMPROVED", "REGRESSED", "TIED", "INDETERMINATE"]
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "stage", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "enum": ["corpus", "baseline", "candidate", "evaluation", "publication"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "source_run_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "properties": {
    "schema_version": {
      "const": 1
    },
    "replay_version": {
      "const": "1"
    },
    "harness_version": {
      "type": "string",
      "minLength": 1
    },
    "replay_id": {
      "type": "string",
      "pattern": "^replay-[0-9]{8}T[0-9]{6}Z-[a-f0-9]{6,32}$"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_run_id": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_package_hash": {
      "$ref": "#/$defs/hash"
    },
    "candidate_patch_hash": {
      "$ref": "#/$defs/hash"
    },
    "hypothesis_policy_hash": {
      "$ref": "#/$defs/hash"
    },
    "source_run_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "success_criterion": {
      "type": "string",
      "minLength": 1
    },
    "evaluator": {
      "const": "control-plane-validation-errors"
    },
    "minimum_effect": {
      "type": "integer",
      "minimum": 1
    },
    "minimum_evidence_count": {
      "type": "integer",
      "minimum": 1
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "corpus_filter": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_run_id",
          "terminal_status",
          "terminal_timestamp",
          "baseline_hash",
          "input_hash",
          "baseline_metric",
          "candidate_metric",
          "effect",
          "classification",
          "error"
        ],
        "properties": {
          "source_run_id": {
            "type": "string",
            "minLength": 1
          },
          "terminal_status": {
            "enum": ["COMMITTED", "ROLLED_BACK", "FAILED"]
          },
          "terminal_timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "baseline_hash": {
            "anyOf": [{"$ref": "#/$defs/hash"}, {"type": "null"}]
          },
          "input_hash": {
            "anyOf": [{"$ref": "#/$defs/hash"}, {"type": "null"}]
          },
          "baseline_metric": {
            "type": ["integer", "null"]
          },
          "candidate_metric": {
            "type": ["integer", "null"]
          },
          "effect": {
            "type": ["integer", "null"]
          },
          "classification": {
            "$ref": "#/$defs/classification"
          },
          "error": {
            "anyOf": [{"$ref": "#/$defs/error"}, {"type": "null"}]
          }
        }
      }
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "counts"],
      "properties": {
        "classification": {
          "$ref": "#/$defs/classification"
        },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "evaluated", "improved", "regressed", "tied", "indeterminate"],
          "properties": {
            "total": {"type": "integer", "minimum": 0},
            "evaluated": {"type": "integer", "minimum": 0},
            "improved": {"type": "integer", "minimum": 0},
            "regressed": {"type": "integer", "minimum": 0},
            "tied": {"type": "integer", "minimum": 0},
            "indeterminate": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/error"
      }
    }
  }
}
