{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/candidate-package.schema.json",
  "title": "Claude Code Control-Plane Candidate Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "run_id",
    "hypothesis_id",
    "patch_hash",
    "hypothesis_policy_hash",
    "package_hash",
    "diff_boundary",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "patch_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "hypothesis_policy_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "package_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "diff_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_paths"
      ],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?:[a-z0-9_.-]*[a-z0-9_-])(?:/(?:[a-z0-9_.-]*[a-z0-9_-]))*$"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^candidate-artifacts/[a-f0-9]{64}-plan\\.json$"
            },
            "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^candidate-artifacts/[a-f0-9]{64}-proposed\\.patch$"
            },
            "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^candidate-artifacts/[a-f0-9]{64}-diff-boundary\\.json$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^candidate-artifacts/[a-f0-9]{64}-hypothesis-policy\\.json$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        }
      ],
      "items": false
    }
  }
}
