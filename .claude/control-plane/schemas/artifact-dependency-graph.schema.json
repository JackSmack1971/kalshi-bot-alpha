{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/artifact-dependency-graph.schema.json",
  "title": "Idea-to-MVP Artifact Dependency Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "artifacts",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "downstream"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{2,63}$"
          },
          "downstream": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]{2,63}$"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
