{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claude-control-plane/workflow-state.schema.json",
  "title": "Idea-to-MVP Workflow State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "mode",
    "current_phase",
    "nodes",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "mode": {
      "enum": [
        "guided",
        "phase-autonomous",
        "guardrailed-autonomous",
        "audit",
        "re-entry"
      ]
    },
    "current_phase": {
      "enum": [
        "discover",
        "define",
        "design",
        "build",
        "test",
        "launch",
        "feedback"
      ]
    },
    "current_node": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 33
        },
        {
          "type": "null"
        }
      ]
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node",
          "phase",
          "status"
        ],
        "properties": {
          "node": {
            "type": "integer",
            "minimum": 1,
            "maximum": 33
          },
          "phase": {
            "enum": [
              "discover",
              "define",
              "design",
              "build",
              "test",
              "launch",
              "feedback"
            ]
          },
          "status": {
            "enum": [
              "pending",
              "eligible",
              "in-progress",
              "blocked",
              "rework",
              "recoverable",
              "complete"
            ]
          },
          "owner": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
          },
          "authoritative_artifacts": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/portablePath"
            },
            "uniqueItems": true
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_human_decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "interruption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changed_paths",
        "recoverable_node",
        "incomplete_handoffs",
        "interrupted_at"
      ],
      "properties": {
        "changed_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/repoRelativePath"
          },
          "uniqueItems": true
        },
        "recoverable_node": {
          "type": "integer",
          "minimum": 1,
          "maximum": 33
        },
        "incomplete_handoffs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^HO-[A-Z0-9-]{4,64}$"
          },
          "uniqueItems": true
        },
        "interrupted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?)(?:/(?:[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?))*$"
    },
    "repoRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.?[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?)(?:/(?:\\.?[a-z0-9_-](?:[a-z0-9._ -]*[a-z0-9_-])?))*$"
    }
  }
}
