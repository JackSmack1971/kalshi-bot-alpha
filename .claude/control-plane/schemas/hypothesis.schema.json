{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/claude-control-plane/hypothesis.schema.json",
  "title": "Hypothesis Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "hypothesis_id",
    "friction_key",
    "target_artifacts",
    "success_criteria",
    "evidence_refs",
    "recurrence_count",
    "impact_score",
    "priority_score",
    "evaluation"
  ],
  "properties": {
    "hypothesis_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "friction_key": {
      "type": "string",
      "minLength": 1
    },
    "target_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "success_criteria": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^\\.claude/control-plane/runs/[^\\s]+$"
      }
    },
    "recurrence_count": {
      "type": "integer",
      "minimum": 1
    },
    "impact_score": {
      "type": "integer",
      "minimum": 0
    },
    "priority_score": {
      "type": "integer",
      "minimum": 0
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluator",
        "minimum_effect",
        "minimum_evidence_count"
      ],
      "properties": {
        "evaluator": {
          "const": "control-plane-validation-errors"
        },
        "minimum_effect": {
          "type": "integer",
          "minimum": 1
        },
        "minimum_evidence_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
