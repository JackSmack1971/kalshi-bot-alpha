# ============================================================================
# TRADING PROCESS ENVIRONMENT (deterministic paper trader) — DEMO ONLY
# ============================================================================
# Values are always empty in this example file. Never commit real values.
# The private key file must live OUTSIDE the repository with permissions
# restricted to the current user.

KALSHI_DEMO_ACCESS_KEY=
KALSHI_DEMO_PRIVATE_KEY_PATH=

# ============================================================================
# PROCESS-ISOLATION RULES (see docs/SAFETY_MODEL.md)
# ============================================================================
# - The trading process must NEVER receive OPENROUTER_API_KEY. Do not add it
#   to this file.
# - The agent control plane runs as a separate process with a separate
#   environment file that contains OPENROUTER_API_KEY and NO Kalshi
#   credentials of any kind.
# - There are no production Kalshi credentials in this project, and no
#   variable naming a production credential may be introduced.
